{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/k-shibuki/reinguard/schemas/gate-artifact.json",
  "title": "GateArtifact",
  "$defs": {
    "gateId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "subject": {
      "type": "object",
      "required": ["head_sha", "branch"],
      "properties": {
        "head_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "branch": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": [
    "schema_version",
    "gate_id",
    "status",
    "recorded_at",
    "subject",
    "producer",
    "inputs",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "gate_id": {
      "$ref": "#/$defs/gateId"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "producer": {
      "type": "object",
      "required": ["procedure", "tool"],
      "properties": {
        "procedure": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate_id", "status", "subject", "recorded_at"],
        "properties": {
          "gate_id": {
            "$ref": "#/$defs/gateId"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "subject": {
            "$ref": "#/$defs/subject"
          },
          "recorded_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "summary"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "skipped"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
