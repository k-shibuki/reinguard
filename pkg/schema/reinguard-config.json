{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/k-shibuki/reinguard/schemas/reinguard-config.json",
  "title": "ReinguardRootConfig",
  "type": "object",
  "required": ["schema_version", "default_branch", "providers"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Synchronized contract version (ADR-0008).",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "default_branch": {
      "type": "string",
      "minLength": 1
    },
    "workflow": {
      "type": "object",
      "description": "Optional workflow overlay: runtime gate role bindings and related PR readiness wiring (see ADR-0014).",
      "additionalProperties": false,
      "properties": {
        "runtime_gate_roles": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "local_verification": {
              "allOf": [
                { "$ref": "#/$defs/runtimeGateRole" },
                {
                  "type": "object",
                  "properties": {
                    "pass_requires_roles": {
                      "type": "array",
                      "maxItems": 0
                    }
                  }
                }
              ]
            },
            "pre_pr_ai_review": {
              "allOf": [
                { "$ref": "#/$defs/runtimeGateRole" },
                {
                  "type": "object",
                  "properties": {
                    "pass_requires_roles": {
                      "type": "array",
                      "uniqueItems": true,
                      "items": {
                        "type": "string",
                        "enum": ["local_verification"]
                      }
                    }
                  }
                }
              ]
            },
            "pr_readiness": {
              "allOf": [
                { "$ref": "#/$defs/runtimeGateRole" },
                {
                  "type": "object",
                  "properties": {
                    "pass_requires_roles": {
                      "type": "array",
                      "uniqueItems": true,
                      "items": {
                        "type": "string",
                        "enum": ["local_verification", "pre_pr_ai_review"]
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "enabled"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "enabled": {
            "type": "boolean"
          },
          "options": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "api_base": {
                "type": "string",
                "minLength": 1,
                "description": "Optional GitHub REST API root override."
              },
              "bot_reviewers": {
                "type": "array",
                "description": "Bot / AI reviewer observation entries for PR issue comments (ADR-0012).",
                "items": {
                  "type": "object",
                  "required": ["id", "login", "required"],
                  "additionalProperties": false,
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[a-z0-9_]+$",
                      "description": "Stable bot identifier for signals and diagnostics."
                    },
                    "login": {
                      "type": "string",
                      "minLength": 1,
                      "description": "GitHub login to match (case-insensitive)."
                    },
                    "required": {
                      "type": "boolean",
                      "description": "When true, bot outcome participates in aggregate merge-readiness-style diagnostics."
                    },
                    "enrich": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      },
                      "description": "Optional built-in enrichment plugin names (e.g. coderabbit)."
                    },
                    "review_triggers": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      },
                      "description": "Optional regex patterns (Go regexp syntax) matched against PR conversation comments not authored by this bot; drives latest_review_trigger_at and review_trigger_awaiting_ack in observation (ADR-0012)."
                    }
                  }
                }
              }
            }
          }
        },
        "additionalProperties": false
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true
    },
    "legacy_tool_hints": {
      "type": "object",
      "description": "Deprecated. Reserved for transitional tooling metadata; do not use in new configs.",
      "additionalProperties": true,
      "deprecated": true
    }
  },
  "$defs": {
    "runtimeGateRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id"],
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "producer_procedures": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pass_check_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pass_requires_roles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": {
          "type": "boolean"
        }
      }
    }
  },
  "additionalProperties": false
}
