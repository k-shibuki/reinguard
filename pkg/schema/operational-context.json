{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/k-shibuki/reinguard/schemas/operational-context.json",
  "title": "OperationalContext",
  "$defs": {
    "resolutionResult": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["resolved", "ambiguous", "degraded", "unsupported"]
        },
        "state_id": { "type": "string" },
        "route_id": { "type": "string" },
        "target_id": { "type": "string" },
        "rule_id": { "type": "string" },
        "reason": { "type": "string" },
        "priority": { "type": "number" },
        "candidates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "route_candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rule_id": { "type": "string" },
              "route_id": { "type": "string" },
              "priority": { "type": "number" }
            },
            "additionalProperties": true
          }
        },
        "missing_evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "re_entry_hint": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "observation": {
      "type": "object",
      "additionalProperties": true
    },
    "state": {
      "$ref": "#/$defs/resolutionResult"
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resolutionResult"
      }
    },
    "guards": {
      "type": "object",
      "additionalProperties": true
    },
    "knowledge": {
      "type": "object",
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "path", "when"],
            "properties": {
              "id": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "triggers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "when": {
                "type": "object",
                "description": "Match expression (ADR-0002) from knowledge manifest.",
                "additionalProperties": true
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": true
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
