{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/k-shibuki/reinguard/schemas/knowledge-manifest.json",
  "title": "KnowledgeManifest",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "description", "triggers"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Repo-relative path to a knowledge file"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "triggers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
