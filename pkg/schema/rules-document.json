{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/k-shibuki/reinguard/schemas/rules-document.json",
  "title": "RulesDocument",
  "type": "object",
  "required": ["rules"],
  "properties": {
    "rules": {
      "type": "array",
      "minItems": 0,
      "items": {
        "allOf": [
          {
            "type": "object",
            "required": ["type", "id", "priority", "when"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["state", "route", "guard"]
              },
              "id": {
                "type": "string",
                "minLength": 1
              },
              "priority": {
                "type": "number"
              },
              "when": {
                "type": "object",
                "description": "Match expression (ADR-0002): op/and/or/not plus optional named eval nodes { \"eval\": \"<name>\", \"params\": { ... } }; evaluator names validated at load.",
                "additionalProperties": true
              },
              "depends_on": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "state_id": {
                "type": "string",
                "minLength": 1
              },
              "route_id": {
                "type": "string",
                "minLength": 1
              },
              "guard_id": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          {
            "if": {
              "properties": { "type": { "const": "guard" } },
              "required": ["type"]
            },
            "then": {
              "required": ["guard_id"]
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
